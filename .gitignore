# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# SQLite database files (contain real user data — never commit)
prisma/*.db
prisma/*.db-shm
prisma/*.db-wal

# Debug / build log files generated during development
build_output.txt
debug_log.txt
ts-errors.txt
migrate-log.txt
migration_log.txt
prisma-error.txt
prisma-migrate-log.txt
prisma_gen_out.txt
prisma_gen_out_v2.txt
prisma_val_out.txt
seed_log.txt
seed_out.txt

# Shell scripts containing server-specific paths (not portable)
/scripts/
